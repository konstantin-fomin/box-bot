# Токен Telegram-бота от @BotFather.
BOT_TOKEN=1234567890:AAEXAMPLE_TOKEN

# Telegram user_id пользователей, которым разрешён доступ.
# Несколько id указываются через запятую.
WHITELIST_USER_IDS=123456789,987654321

# Telegram chat_id канала для ежедневных zip-бэкапов базы.
# Бот должен быть добавлен в канал и иметь право отправлять сообщения.
BACKUP_CHAT_ID=-1001234567890
